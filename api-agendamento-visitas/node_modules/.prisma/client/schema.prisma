// Prisma schema para o sistema de agendamento de visitas
// MySQL como banco de dados

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Appointment {
  id_agendamento Int @id @default(autoincrement())

  // IDs opcionais para permitir folgas e reuniões genéricas
  id_locador   Int?
  id_locatario Int?
  id_imovel    Int?

  // @unique removido conforme alinhamento com o P.O.
  data DateTime

  tipo      String            @db.Text
  status    AppointmentStatus @default(SCHEDULED)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@map("agendamento")
}

enum Role {
  USER
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  CANCELED
  COMPLETED
}
